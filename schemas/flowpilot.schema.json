{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ubs.internal/flowpilot/schemas/flowpilot.schema.json",
  "title": "UBS FlowPilot Configuration",
  "type": "object",
  "required": ["name", "version", "knowledge", "workflows"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "defaultRole": {
      "enum": ["ba", "developer", "tester", "support", "tech-lead"]
    },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "repositories"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "knowledgeRoots": {
            "type": "array",
            "items": { "type": "string" }
          },
          "actions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hidden": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "repositories": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "path", "gitlabProjectId"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "gitlabProjectId": { "type": ["string", "integer"] },
                "type": {
                  "enum": [
                    "service",
                    "frontend",
                    "batch-worker",
                    "library",
                    "test-automation",
                    "infrastructure",
                    "other"
                  ]
                },
                "defaultBranch": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "gitlab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "format": "uri"
        },
        "defaultGroup": {
          "type": "string"
        },
        "projectMappings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["repoPath", "projectId"],
            "additionalProperties": false,
            "properties": {
              "repoPath": { "type": "string" },
              "projectId": { "type": ["string", "integer"] }
            }
          }
        }
      }
    },
    "knowledge": {
      "type": "object",
      "required": ["roots"],
      "additionalProperties": false,
      "properties": {
        "roots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "ignore": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflows": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "gatewayUrl": { "type": "string", "format": "uri" },
        "environments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "allowed"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "allowed": {
                "oneOf": [
                  { "type": "boolean" },
                  { "enum": ["readOnly"] }
                ]
              }
            }
          }
        }
      }
    }
  }
}
